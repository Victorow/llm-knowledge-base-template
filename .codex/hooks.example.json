{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory /ABSOLUTE/PATH/TO/llm-knowledge-base python /ABSOLUTE/PATH/TO/llm-knowledge-base/hooks/session-start.py",
            "timeout": 15,
            "statusMessage": "Loading knowledge base context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "uv run --directory /ABSOLUTE/PATH/TO/llm-knowledge-base python /ABSOLUTE/PATH/TO/llm-knowledge-base/hooks/session-end.py",
            "timeout": 10,
            "statusMessage": "Saving knowledge base memory"
          }
        ]
      }
    ]
  }
}
