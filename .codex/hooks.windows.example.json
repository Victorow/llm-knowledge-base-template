{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"uv run --directory 'C:\\ABSOLUTE\\PATH\\TO\\llm-knowledge-base' python 'C:\\ABSOLUTE\\PATH\\TO\\llm-knowledge-base\\hooks\\session-start.py'\"",
            "timeout": 15,
            "statusMessage": "Loading knowledge base context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"uv run --directory 'C:\\ABSOLUTE\\PATH\\TO\\llm-knowledge-base' python 'C:\\ABSOLUTE\\PATH\\TO\\llm-knowledge-base\\hooks\\session-end.py'\"",
            "timeout": 10,
            "statusMessage": "Saving knowledge base memory"
          }
        ]
      }
    ]
  }
}
