          {
            "type": "command",
            "command": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"uv run --directory 'C:\\ABSOLUTE\\PATH\\TO\\llm-knowledge-base' python 'C:\\ABSOLUTE\\PATH\\TO\\llm-knowledge-base\\hooks\\pre-compact.py'\"",
